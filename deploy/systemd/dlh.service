[Unit]
Description=DLH Tasikmalaya Flask App
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/dlh_tasikmalaya_enterprise_flask
Environment="PATH=/var/www/dlh_tasikmalaya_enterprise_flask/.venv/bin"
ExecStart=/var/www/dlh_tasikmalaya_enterprise_flask/.venv/bin/gunicorn -w 3 -b 127.0.0.1:8000 wsgi:app
Restart=always

[Install]
WantedBy=multi-user.target
